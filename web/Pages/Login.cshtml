@page
@model web.Pages.LoginModel
@{
    ViewData["Title"] = "Авторизация";
}

<style>
    body {
        background-image: url('/images/graphics/patternbg.png');
        background-repeat: repeat;
        background-position: top left;
        background-attachment: fixed;
    }
</style>

<div style="display: flex; justify-content: center; align-items: center; min-height: 80vh; padding: 20px;">
    <div style="width: 100%; max-width: 450px; background-color: white; border-radius: 20px; box-shadow: 0 4px 20px rgba(0,0,0,0.1); padding: 40px;">

        <!-- ЗАГОЛОВОК (как ФИО автора) -->
        <h2 style="margin: 0 0 30px 0; font-size: 46px; color: #4c60d1; font-weight: bold; letter-spacing: -0.5px; text-align: center;">
            Вход в систему
        </h2>

        <form method="post">
            <!-- ЛОГИН -->
            <div style="margin-bottom: 25px;">
                <label style="display: block; margin-bottom: 8px; font-size: 14px; font-weight: bold; color: #000000;">ЛОГИН</label>
                <input type="text"
                       name="login"
                       required
                       autocomplete="off"
                       style="width: 100%; padding: 12px 15px; font-size: 14px; border: 2px solid #4c60d1; border-radius: 30px; box-sizing: border-box; outline: none; transition: 0.3s; font-family: 'Consolas', monospace;"
                       onfocus="this.style.borderColor='#7a8ce5'; this.style.boxShadow='0 0 5px rgba(76,96,209,0.3)'"
                       onblur="this.style.borderColor='#4c60d1'; this.style.boxShadow='none'" />
            </div>

            <!-- ПАРОЛЬ -->
            <div style="margin-bottom: 30px;">
                <label style="display: block; margin-bottom: 8px; font-size: 14px; font-weight: bold; color: #000000;">ПАРОЛЬ</label>
                <input type="password"
                       name="password"
                       required
                       style="width: 100%; padding: 12px 15px; font-size: 14px; border: 2px solid #4c60d1; border-radius: 30px; box-sizing: border-box; outline: none; transition: 0.3s; font-family: 'Consolas', monospace;"
                       onfocus="this.style.borderColor='#7a8ce5'; this.style.boxShadow='0 0 5px rgba(76,96,209,0.3)'"
                       onblur="this.style.borderColor='#4c60d1'; this.style.boxShadow='none'" />
            </div>

            <!-- КНОПКА ВОЙТИ (как кнопка "Купить" у авторов) -->
            <button type="submit"
                    style="width: 100%; padding: 12px; background-color: #4c60d1; color: white; border: none; border-radius: 30px; font-size: 16px; font-weight: bold; cursor: pointer; transition: background-color 0.3s; margin-bottom: 20px; font-family: 'Consolas', monospace;"
                    onmouseover="this.style.backgroundColor='#7a8ce5'"
                    onmouseout="this.style.backgroundColor='#4c60d1'">
                Войти
            </button>
        </form>

        <!-- СООБЩЕНИЕ ОБ ОШИБКЕ -->
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <p style="color: gray; margin-top: 15px; font-size: 13px; text-align: center;">@Model.ErrorMessage</p>
        }

        <!-- ССЫЛКА НА РЕГИСТРАЦИЮ -->
        <p style="margin-top: 20px; font-size: 13px; text-align: center; color: gray;">
            Нет аккаунта? <a href="/Register" style="color: #4c60d1; text-decoration: none; font-weight: bold;">Регистрация</a>
        </p>

    </div>
</div>