@page
@model web.Pages.LoginModel
@{
    ViewData["Title"] = "Авторизация";
}

<div style="width: 300px; margin: 50px auto; padding: 20px; border: 1px solid #ccc; background-color: #f9f9f9; font-family: sans-serif;">
    <h3 style="margin-top: 0;">Вход в систему</h3>
    <hr />

    <form method="post">
        <div style="margin-bottom: 10px;">
            <label>Логин:</label><br />
            <input type="text" name="login" required style="width: 100%; padding: 4px; box-sizing: border-box;" autocomplete="off" />
        </div>
        <div style="margin-bottom: 15px;">
            <label>Пароль:</label><br />
            <input type="password" name="password" required style="width: 100%; padding: 4px; box-sizing: border-box;" />
        </div>

        <input type="submit" value="Войти" style="width: 100%; padding: 6px; cursor: pointer;" />
    </form>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <p style="color: #b22222; margin-top: 15px; font-size: 13px; font-weight: bold;">@Model.ErrorMessage</p>
    }

    <p style="margin-top: 15px; font-size: 13px; text-align: center; margin-bottom: 0;">
        Нет аккаунта? <a href="/Register">Регистрация</a>
    </p>
</div>