@page
@model web.Pages.IndexModel
@{
    ViewData["Title"] = "Главная";
}

<div style="position: relative; width: 100%; max-width: 900px; margin: 0 auto 40px auto; overflow: hidden; border-radius: 15px; box-shadow: 0 4px 15px rgba(0,0,0,0.1);">

    <!-- Контейнер для слайдов -->
    <div id="bannerSlider" style="display: flex; transition: transform 0.5s ease-in-out; width: 100%;">

        <!-- БАННЕР 1 - ПРОСТО КАРТИНКА -->
        <div style="flex: 0 0 100%; position: relative;">
            <img src="/images/graphics/banners/Banner1.jpg" alt="Баннер 1" style="width: 100%; height: 100%; object-fit: cover; display: block;" />
        </div>

        <!-- БАННЕР 2 - ПРОСТО КАРТИНКА -->
        <div style="flex: 0 0 100%; position: relative;">
            <img src="/images/graphics/banners/Banner2.jpg" alt="Баннер 2" style="width: 100%; height: 100%; object-fit: cover; display: block;" />
        </div>

    </div>

    <!-- КНОПКА НАЗАД -->
    <button onclick="prevSlide()" style="position: absolute; left: 10px; top: 50%; transform: translateY(-50%); background-color: rgba(0,0,0,0.5); color: white; border: none; border-radius: 50%; width: 40px; height: 40px; cursor: pointer; font-size: 20px; display: flex; align-items: center; justify-content: center; z-index: 10;">
        ❮
    </button>

    <!-- КНОПКА ВПЕРЕД -->
    <button onclick="nextSlide()" style="position: absolute; right: 10px; top: 50%; transform: translateY(-50%); background-color: rgba(0,0,0,0.5); color: white; border: none; border-radius: 50%; width: 40px; height: 40px; cursor: pointer; font-size: 20px; display: flex; align-items: center; justify-content: center; z-index: 10;">
        ❯
    </button>

    <!-- ИНДИКАТОРЫ (ТОЧКИ) -->
    <div id="bannerDots" style="position: absolute; bottom: 15px; left: 50%; transform: translateX(-50%); display: flex; gap: 10px; z-index: 10;"></div>
</div>

<!-- СЕКЦИЯ С КНИГАМИ ИЗДАТЕЛЬСТВА №4 (ЗАГРУЖАЕТСЯ СРАЗУ) -->
<div id="supplierBooksSection" style="margin-top: 50px;">
    <h3>Эксклюзив от "Книжной реликвии"</h3>
    <div id="supplierBooksContainer">
        <p style="color: gray;">Загрузка...</p>
    </div>
</div>

<script>
    let currentSlide = 0;
    const slider = document.getElementById('bannerSlider');
    const slides = document.querySelectorAll('#bannerSlider > div');
    const totalSlides = slides.length;
    const dotsContainer = document.getElementById('bannerDots');
    let dots = [];

    function createDots() {
        for (let i = 0; i < totalSlides; i++) {
            const dot = document.createElement('div');
            dot.style.width = '10px';
            dot.style.height = '10px';
            dot.style.borderRadius = '50%';
            dot.style.backgroundColor = 'white';
            dot.style.cursor = 'pointer';
            dot.style.opacity = i === currentSlide ? '1' : '0.5';
            dot.onclick = () => goToSlide(i);
            dotsContainer.appendChild(dot);
            dots.push(dot);
        }
    }

    function updateSlider() {
        slider.style.transform = `translateX(-${currentSlide * 100}%)`;
        dots.forEach((dot, index) => {
            dot.style.opacity = index === currentSlide ? '1' : '0.5';
        });
    }

    function nextSlide() {
        currentSlide = (currentSlide + 1) % totalSlides;
        updateSlider();
    }

    function prevSlide() {
        currentSlide = (currentSlide - 1 + totalSlides) % totalSlides;
        updateSlider();
    }

    function goToSlide(index) {
        currentSlide = index;
        updateSlider();
    }

 
    function loadSupplierBooks() {
        fetch('/Books?SelectedSupplierId=4')
            .then(response => response.text())
            .then(html => {
                const temp = document.createElement('div');
                temp.innerHTML = html;
                const booksGrid = temp.querySelector('div[style*="grid-template-columns"]');

                if (booksGrid) {
                    document.getElementById('supplierBooksContainer').innerHTML = '';
                    document.getElementById('supplierBooksContainer').appendChild(booksGrid.cloneNode(true));
                } else {
                    document.getElementById('supplierBooksContainer').innerHTML = '<p style="color: gray;">Нет книг этого издательства</p>';
                }
            })
            .catch(() => {
                document.getElementById('supplierBooksContainer').innerHTML = '<p style="color: red;">Ошибка загрузки</p>';
            });
    }

    createDots();
    setInterval(nextSlide, 5000);

    loadSupplierBooks();
</script>