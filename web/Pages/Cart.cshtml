@page
@model web.Pages.CartModel
@{
    ViewData["Title"] = "Корзина покупателя";
}

<!-- ВЕРХНИЙ БЛОК: КАК НА СТРАНИЦЕ АВТОРА -->
<div style="margin-top: 10px;">
    <div style="display: grid; grid-template-columns: 1fr; gap: 40px; margin-bottom: 35px;">
        <div style="display: flex; flex-direction: column; justify-content: flex-start; min-width: 0;">

            <h2 style="margin: 0 0 5px 0; font-size: 46px; color: #4c60d1; font-weight: bold; letter-spacing: -0.5px;">
                Корзина
            </h2>

        </div>
    </div>
</div>

<!-- СООБЩЕНИЕ ОБ УСПЕХЕ -->
@if (TempData["SuccessMessage"] != null)
{
    <div style="background-color: #d4edda; color: #155724; padding: 15px; border-radius: 8px; margin-bottom: 20px; text-align: center; border: 1px solid #c3e6cb;">
        @TempData["SuccessMessage"]
    </div>
}

<!-- СООБЩЕНИЕ ОБ ОШИБКЕ ИЛИ СТАТУСЕ ЗАКАЗА -->
@if (!string.IsNullOrEmpty(Model.OrderMessage))
{
    <div style="background-color: #f8d7da; color: #721c24; padding: 15px; border-radius: 8px; margin-bottom: 20px; text-align: center; border: 1px solid #f5c6cb;">
        @Model.OrderMessage
    </div>
}

@if (Model.CartItems == null || !Model.CartItems.Any())
{
    <p style="color: gray; text-align: center;">Ваша корзина пуста. <a asp-page="/Books">Перейти в каталог</a></p>
}
else
{
    <div style="display: flex; gap: 30px; flex-wrap: wrap;">

        <!-- ЛЕВАЯ КОЛОНКА: Товары -->
        <div style="flex: 2; min-width: 300px;">

            <!-- Кнопки выбора -->
            <div style="margin-bottom: 15px; display: flex; gap: 10px;">
                <button type="button" id="selectAllBtn" style="background-color: #4c60d1; color: white; border: none; padding: 5px 15px; border-radius: 15px; cursor: pointer; font-size: 12px;">Выбрать все</button>
                <button type="button" id="deselectAllBtn" style="background-color: #333333; color: white; border: none; padding: 5px 15px; border-radius: 15px; cursor: pointer; font-size: 12px;">Снять выделение</button>
            </div>

            @foreach (var item in Model.CartItems)
            {
                <!-- КАРТОЧКА ТОВАРА С ГАЛОЧКОЙ -->
                <div class="cart-item" style="background-color: #f5f5f5; border-radius: 12px; padding: 15px; margin-bottom: 15px; display: flex; gap: 15px;">

                    <!-- ГАЛОЧКА ДЛЯ ВЫБОРА -->
                    <div style="display: flex; align-items: center;">
                        <input type="checkbox" class="item-checkbox" data-id="@item.CartItemId" data-price="@item.PricePerUnit" data-name="@item.BookName" checked style="width: 20px; height: 20px; cursor: pointer;" />
                    </div>

                    <!-- ОБЛОЖКА -->
                    <div style="width: 100px; flex-shrink: 0; overflow: hidden; border-radius: 8px;">
                        @if (!string.IsNullOrEmpty(item.BookImagePath))
                        {
                            <img src="@item.BookImagePath" alt="Обложка" style="width: 100%; height: 100%; object-fit: cover;" />
                        }
                        else
                        {
                            <div style="width: 100%; height: 100%; min-height: 120px; background-color: #e0e0e0; display: flex; align-items: center; justify-content: center; font-size: 10px; color: #999;">нет фото</div>
                        }
                    </div>

                    <!-- ПРАВАЯ ЧАСТЬ -->
                    <div style="flex: 1;">

                        <!-- ВЕРХНЯЯ СТРОКА: название и количество -->
                        <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 10px;">
                            <a href="/BookDetails?id=@item.BookId" style="font-size: 18px; font-weight: bold; color: #4c60d1; text-decoration: none;">
                                @item.BookName
                            </a>

                            <div style="display: flex; align-items: center; gap: 8px;">
                                <span style="font-size: 13px; color: #666;">Кол-во:</span>
                                <div style="display: flex; align-items: center; gap: 5px;">
                                    <button type="button" class="qty-minus" data-id="@item.CartItemId" data-price="@item.PricePerUnit" data-max="@item.MaxAvailable" style="width: 28px; height: 28px; border-radius: 50%; border: 1px solid #ccc; background-color: white; cursor: pointer; font-size: 16px;">-</button>
                                    <input type="text"
                                           class="quantity-input"
                                           data-id="@item.CartItemId"
                                           data-price="@item.PricePerUnit"
                                           value="@item.Quantity"
                                           min="1"
                                           max="@item.MaxAvailable"
                                           style="width: 50px; padding: 4px; border: 1px solid #ccc; border-radius: 5px; text-align: center;" />
                                    <button type="button" class="qty-plus" data-id="@item.CartItemId" data-price="@item.PricePerUnit" data-max="@item.MaxAvailable" style="width: 28px; height: 28px; border-radius: 50%; border: 1px solid #ccc; background-color: white; cursor: pointer; font-size: 16px;">+</button>
                                </div>
                            </div>
                        </div>

                        <!-- ТИП КНИГИ -->
                        <div style="margin-bottom: 10px;">
                            @if (item.SupplierName == "Электронная версия")
                            {
                                <span style="display: inline-block; padding: 4px 12px; background-color: white; border: 1px solid #4c60d1; border-radius: 20px; font-size: 12px; color: #4c60d1; font-weight: 500;">Электронное издание</span>
                            }
                            else
                            {
                                <span style="display: inline-block; padding: 4px 12px; background-color: white; border: 1px solid #4c60d1; border-radius: 20px; font-size: 12px; color: #4c60d1; font-weight: 500;">Физическое издание</span>
                                <span style="font-size: 12px; color: #666; margin-left: 10px;">Поставщик: @item.SupplierName</span>
                            }
                        </div>

                        <!-- ДОСТУПНОСТЬ -->
                        <div style="margin-bottom: 12px; padding-left: 10px;">
                            @if (item.SupplierName == "Электронная версия")
                            {
                                <span style="font-size: 12px; color: #4c60d1;">Доступно всегда</span>
                            }
                            else
                            {
                                <span style="font-size: 12px; color: @(item.MaxAvailable > 0 ? "green" : "red");">
                                    @(item.MaxAvailable > 0 ? $"В наличии: {item.MaxAvailable} шт." : "Нет в наличии")
                                </span>
                            }
                        </div>

                        <!-- НИЖНЯЯ СТРОКА: цена и удаление -->
                        <div style="display: flex; justify-content: flex-end; align-items: center; gap: 15px; margin-top: 5px;">
                            <div style="text-align: right;">
                                <span style="font-size: 13px; color: #666;">Цена за шт.:</span>
                                <span style="font-size: 16px; font-weight: bold; color: gray;">@item.PricePerUnit.ToString("N2") руб.</span>
                                <div style="margin-top: 3px;">
                                    <span style="font-size: 14px; font-weight: bold;">Сумма:</span>
                                    <span class="item-total" data-id="@item.CartItemId" style="font-size: 18px; font-weight: bold; color: #4c60d1;">@item.TotalPrice.ToString("N2") руб.</span>
                                </div>
                                <form method="post" asp-page-handler="RemoveItem" style="display: inline-block; margin-top: 8px;" onsubmit="return confirm('Удалить товар из корзины?');">
                                    <input type="hidden" name="cartItemId" value="@item.CartItemId" />
                                    <button type="submit" style="background-color: #333333; color: white; border: none; padding: 4px 12px; border-radius: 15px; cursor: pointer; font-size: 12px;">Удалить</button>
                                </form>
                            </div>
                        </div>

                    </div>
                </div>
            }

            <!-- ИТОГО (только для выбранных товаров) -->
            <div style="text-align: right; margin-top: 20px; padding: 15px;">
                <h2 style="margin: 0; font-size: 28px; color: #4c60d1; font-weight: bold;">
                    Итого к оплате: <span id="selectedTotalSum" style="color: #4c60d1;">0 руб.</span>
                </h2>
            </div>

            <!-- Кнопка очистки корзины -->
            <div style="margin-top: 15px; text-align: left;">
                <form method="post" asp-page-handler="Clear">
                    <button type="submit" style="background-color: #333333; color: white; border: none; padding: 8px 20px; border-radius: 20px; cursor: pointer;">Очистить корзину</button>
                </form>
            </div>
        </div>

        <!-- ПРАВАЯ КОЛОНКА: Оформление заказа -->
        <div style="flex: 1; min-width: 280px;">
            <div style="border: 1px solid #ddd; padding: 20px; border-radius: 10px; background-color: #fff;">
                <h3 style="margin-top: 0; font-size: 20px; color: #4c60d1; font-weight: bold;">Оформление заказа</h3>

                <form method="post" asp-page-handler="Checkout" id="checkoutForm">
                    <input type="hidden" name="selectedItems" id="selectedItemsInput" value="" />

                    @{
                        var hasPhysicalBooks = Model.CartItems.Any(i => i.SupplierName != "Электронная версия");
                        var hasElectronicBooks = Model.CartItems.Any(i => i.SupplierName == "Электронная версия");
                    }

                    @if (hasPhysicalBooks && hasElectronicBooks)
                    {
                        <div style="margin-bottom: 15px;">
                            <label style="display: block; font-weight: bold; margin-bottom: 5px;">Почтовый индекс</label>
                            <select asp-for="AddressIndex" required style="width: 100%; padding: 8px; border-radius: 5px; border: 1px solid #ccc; color: gray;">
                                <option value="" style="color: gray;">-- Выберите индекс --</option>
                                @foreach (var index in Model.OrderIndicesList)
                                {
                                    if (index != "0")
                                    {
                                        <option value="@index">@index</option>
                                    }
                                }
                            </select>
                        </div>
                        <div style="margin-bottom: 15px; padding: 12px; background-color: #d4e4fc; border-radius: 5px; text-align: left;">
                            <span style="color: #4c60d1;">Электронные издания будут отправлены на почту, которую вы указали при регистрации (<strong>@Model.MaskedEmail</strong>)</span>
                        </div>
                    }
                    else if (hasPhysicalBooks)
                    {
                        <div style="margin-bottom: 15px;">
                            <label style="display: block; font-weight: bold; margin-bottom: 5px;">Почтовый индекс</label>
                            <select asp-for="AddressIndex" required style="width: 100%; padding: 8px; border-radius: 5px; border: 1px solid #ccc; color: gray;">
                                <option value="" style="color: gray;">-- Выберите индекс --</option>
                                @foreach (var index in Model.OrderIndicesList)
                                {
                                    if (index != "0")
                                    {
                                        <option value="@index">@index</option>
                                    }
                                }
                            </select>
                        </div>
                    }
                    else
                    {
                        <div style="margin-bottom: 15px; padding: 12px; background-color: #d4e4fc; border-radius: 5px; text-align: left;">
                            <span style="color: #4c60d1;">Электронные издания будут отправлены на почту, которую вы указали при регистрации (<strong>@Model.MaskedEmail</strong>)</span>
                        </div>
                    }

                    <button type="submit" style="width: 100%; background-color: #4c60d1; color: white; border: none; padding: 12px; border-radius: 20px; font-size: 16px; font-weight: bold; cursor: pointer;">
                        Оформить заказ
                    </button>
                </form>
            </div>
        </div>

    </div>
}

<script>
    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

    function updateSelectedTotal() {
        let total = 0;
        document.querySelectorAll('.item-checkbox:checked').forEach(checkbox => {
            const cartItemId = checkbox.getAttribute('data-id');
            const itemTotalSpan = document.querySelector(`.item-total[data-id="${cartItemId}"]`);
            if (itemTotalSpan) {
                let val = parseFloat(itemTotalSpan.innerText);
                if (!isNaN(val)) total += val;
            }
        });
        document.getElementById('selectedTotalSum').innerText = total.toFixed(2) + ' руб.';
    }

    function updateQuantity(cartItemId, quantity, price) {
        fetch('/Cart?handler=UpdateQuantity', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
                'RequestVerificationToken': token
            },
            body: 'cartItemId=' + encodeURIComponent(cartItemId) + '&quantity=' + encodeURIComponent(quantity)
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                const itemTotalSpan = document.querySelector(`.item-total[data-id="${cartItemId}"]`);
                if (itemTotalSpan) {
                    const newTotal = price * quantity;
                    itemTotalSpan.innerText = newTotal.toFixed(2) + ' руб.';
                }
                updateSelectedTotal();
            }
        })
        .catch(error => console.error('Error:', error));
    }

    document.querySelectorAll('.quantity-input').forEach(input => {
        input.addEventListener('change', function(e) {
            const cartItemId = this.getAttribute('data-id');
            let quantity = parseInt(this.value);
            const maxAvailable = parseInt(this.getAttribute('max'));
            const price = parseFloat(this.getAttribute('data-price'));

            if (isNaN(quantity) || quantity < 1) {
                quantity = 1;
                this.value = 1;
            } else if (quantity > maxAvailable) {
                quantity = maxAvailable;
                this.value = maxAvailable;
            }
            updateQuantity(cartItemId, quantity, price);
        });
    });

    document.querySelectorAll('.qty-plus').forEach(btn => {
        btn.addEventListener('click', function() {
            const cartItemId = this.getAttribute('data-id');
            const input = document.querySelector(`.quantity-input[data-id="${cartItemId}"]`);
            let quantity = parseInt(input.value);
            const maxAvailable = parseInt(this.getAttribute('data-max'));
            const price = parseFloat(this.getAttribute('data-price'));

            if (quantity < maxAvailable) {
                quantity++;
                input.value = quantity;
                updateQuantity(cartItemId, quantity, price);
            }
        });
    });

    document.querySelectorAll('.qty-minus').forEach(btn => {
        btn.addEventListener('click', function() {
            const cartItemId = this.getAttribute('data-id');
            const input = document.querySelector(`.quantity-input[data-id="${cartItemId}"]`);
            let quantity = parseInt(input.value);
            const price = parseFloat(this.getAttribute('data-price'));

            if (quantity > 1) {
                quantity--;
                input.value = quantity;
                updateQuantity(cartItemId, quantity, price);
            }
        });
    });

    document.querySelectorAll('.item-checkbox').forEach(checkbox => {
        checkbox.addEventListener('change', function() {
            updateSelectedTotal();
        });
    });

    document.getElementById('selectAllBtn')?.addEventListener('click', function() {
        document.querySelectorAll('.item-checkbox').forEach(cb => cb.checked = true);
        updateSelectedTotal();
    });

    document.getElementById('deselectAllBtn')?.addEventListener('click', function() {
        document.querySelectorAll('.item-checkbox').forEach(cb => cb.checked = false);
        updateSelectedTotal();
    });

    document.getElementById('checkoutForm')?.addEventListener('submit', function(e) {
        const selectedIds = [];
        document.querySelectorAll('.item-checkbox:checked').forEach(cb => {
            selectedIds.push(cb.getAttribute('data-id'));
        });
        document.getElementById('selectedItemsInput').value = selectedIds.join(',');

        if (selectedIds.length === 0) {
            e.preventDefault();
            alert('Выберите хотя бы один товар для оформления заказа');
        }
    });

    updateSelectedTotal();
</script>