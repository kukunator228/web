@page
@model web.Pages.BookDetailsModel
@{
    ViewData["Title"] = Model.CurrentBook?.BookName ?? "Детали книги";
}

@if (TempData["CartMessage"] != null)
{
    <div style="background-color: #d4edda; color: #155724; padding: 12px; border-radius: 8px; margin-bottom: 20px; text-align: center; border: 1px solid #c3e6cb;">
        @TempData["CartMessage"]
        <a asp-page="/Cart" style="color: #155724; font-weight: bold; margin-left: 10px;">Перейти в корзину</a>
    </div>
}

@if (Model.CurrentBook == null)
{
    <div style="text-align: center; margin-top: 50px;">
        <p style="color: red; font-size: 18px;">@Model.ReviewErrorMessage</p>
        <p><a asp-page="/Books">Вернуться к списку книг</a></p>
    </div>
}
else
{
    <div style="margin-top: 10px;">

        <!-- ВЕРХНИЙ БЛОК: СЕТКА ДЛЯ ОБЛОЖКИ И ИНФОРМАЦИИ -->
        <div style="display: grid; grid-template-columns: 280px 1fr; gap: 40px; margin-bottom: 35px;">

            <!-- ЛЕВАЯ КОЛОНКА: Обложка -->
            <div>
                <div style="width: 100%; aspect-ratio: 2/3; overflow: hidden; border: 0px solid transparent; background-color: white; border-radius: 10px; box-shadow: 0 4px 10px rgba(0,0,0,0.08);">
                    @if (!string.IsNullOrEmpty(Model.CurrentBook.ImagePath))
                    {
                        <img src="@Model.CurrentBook.ImagePath" alt="Обложка книги" style="width: 100%; height: 100%; object-fit: cover;" />
                    }
                    else
                    {
                        <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; color: #7a7c56; font-weight: bold;">
                            [НЕТ ОБЛОЖКИ]
                        </div>
                    }
                </div>
            </div>

            <!-- ПРАВАЯ КОЛОНКА -->
            <div style="display: flex; flex-direction: column; justify-content: flex-start; min-width: 0;">

                <h2 style="margin: 0 0 5px 0; font-size: 46px; color: #4c60d1; font-weight: bold; letter-spacing: -0.5px;">
                    @Model.CurrentBook.BookName
                </h2>

                <!-- АВТОР (кликабельный) -->
                <p style="margin: 0 0 10px 0; font-size: 14px; color: #000000; line-height: 1.6;">
                    <b>Автор:</b>
                    @if (Model.AuthorsList != null && Model.AuthorsList.Any())
                    {
                        @foreach (var author in Model.AuthorsList)
                        {
                            <a href="/AuthorBooks/@author.AuthorId" style="color: #4c60d1; text-decoration: none; font-weight: 500;">
                                @($"{author.AuthorSecondName} {author.AuthorFirstName} {author.AuthorPatronymic}".Trim())
                            </a>
                            if (author != Model.AuthorsList.Last())
                            {
                                <text>, </text>
                            }
                        }
                    }
                    else
                    {
                        <span class="status-null">Автор не указан</span>
                    }
                </p>

                <!-- ЖАНРЫ КНИГИ -->
                @if (Model.CurrentBook.BookGenres != null && Model.CurrentBook.BookGenres.Any())
                {
                    <div style="margin-bottom: 15px;">
                        <b>Жанры:</b>
                        <span style="color: #4c60d1; font-weight: 500;">
                            @string.Join(", ", Model.CurrentBook.BookGenres.Select(bg => bg.GenreKeyNavigation?.GenreName))
                        </span>
                    </div>
                }

                <p style="margin: 0 0 5px 0; font-size: 14px; color: #000000; line-height: 1.6; white-space: pre-line;">
                    @if (!string.IsNullOrEmpty(Model.CurrentBook.BookDesc))
                    {
                        @Model.CurrentBook.BookDesc
                    }
                    else
                    {
                        <span style="color: grey; font-style: italic;">Описание отсутствует.</span>
                    }
                </p>

                <!-- ВЫБОР ТИПА КНИГИ -->
                @if (Model.CurrentBook.BookBooktypes != null && Model.CurrentBook.BookBooktypes.Any())
                {
                    <div style="margin-bottom: 15px;">
                        <b>Выберите тип:</b>
                        <select id="selectedBookType" style="margin-left: 10px; padding: 5px; border-radius: 5px; border: 1px solid #b0b288;">
                            @foreach (var bookType in Model.CurrentBook.BookBooktypes)
                            {
                                if (bookType.BookTypeKeyNavigation != null)
                                {
                                    <option value="@bookType.BookTypeKey">@bookType.BookTypeKeyNavigation.BookTypeName</option>
                                }
                            }
                        </select>
                    </div>
                }

                <!-- ДОСТУПНЫЕ ПРЕДЛОЖЕНИЯ -->
                <div id="suppliesContainer" style="margin-top: 10px;">
                    <!-- Физические предложения (из БД) -->
                    <div id="physicalSupplies">
                        @if (Model.CurrentBook.BookSupplies != null && Model.CurrentBook.BookSupplies.Any())
                        {
                            <b>Физические книги:</b>
                            @foreach (var supply in Model.CurrentBook.BookSupplies.OrderBy(s => s.BookSupplyPiecePrice * 1.6m))
                            {
                                var isAvailable = int.Parse(supply.SupplyQuantity) > 0;
                                <div class="supply-item physical-item" data-supply-id="@supply.BookSupplyId" data-book-type="4" style="border: 1px solid #ccc; padding: 12px; margin-bottom: 10px; border-radius: 15px; background-color: #f9f9f9;">
                                    <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 10px;">
                                        <div>
                                            <b>@(supply.SupplierKeyNavigation?.SupplierName ?? "Неизвестный поставщик")</b>
                                            <br />
                                            <span style="font-size: 12px; color: @(isAvailable ? "green" : "gray");">
                                                @(isAvailable ? "В наличии" : "Нет в наличии")
                                            </span>
                                        </div>
                                        <div style="text-align: right;">
                                            <span style="color: #4c60d1; font-size: 24px; font-weight: bold;">
                                                @((supply.BookSupplyPiecePrice * 1.6m).ToString("N2")) руб.
                                            </span>
                                            @if (isAvailable)
                                            {
                                                <form method="post" asp-page-handler="AddToCart" style="margin-top: 8px;">
                                                    <input type="hidden" name="supplyId" value="@supply.BookSupplyId" />
                                                    <input type="hidden" name="bookTypeId" value="4" />
                                                    <input type="number" name="quantity" min="1" max="@int.Parse(supply.SupplyQuantity)" value="1" style="width: 60px; margin-right: 5px; padding: 5px; border: 1px solid #ccc; border-radius: 5px;" />
                                                    <input type="submit" value="В корзину" style="background-color: #4c60d1; color: white; border: none; padding: 6px 15px; border-radius: 20px; cursor: pointer;" />
                                                </form>
                                            }
                                            else
                                            {
                                                <button disabled style="background-color: #ccc; color: white; border: none; padding: 6px 15px; border-radius: 20px; margin-top: 8px;">Нет в наличии</button>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                    </div>

                    <!-- Электронное предложение (виртуальное) -->
                    <div id="electronicSupply" style="display: none;">
                        <b>Электронная книга:</b>
                        <div style="border: 1px solid #4c60d1; padding: 12px; margin-bottom: 10px; border-radius: 15px; background-color: #e8f4fd;" data-book-type="1">
                            <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 10px;">
                                <div>
                                    <b>Электронная версия</b>
                                    <br />
                                    <span style="font-size: 12px; color: #4c60d1;">
                                        Доступна всегда (ссылка придёт на email)
                                    </span>
                                </div>
                                <div style="text-align: right;">
                                    <span style="color: #4c60d1; font-size: 24px; font-weight: bold;">
                                        @((Model.CurrentBook.BookSupplies?.FirstOrDefault()?.BookSupplyPiecePrice * 1.6m ?? 500).ToString("N2")) руб.
                                    </span>
                                    <form method="post" asp-page-handler="AddElectronicToCart" style="margin-top: 8px;">
                                        <input type="hidden" name="bookId" value="@Model.CurrentBook.BookId" />
                                        <input type="hidden" name="bookTypeId" value="1" />
                                        <input type="number" name="quantity" min="1" value="1" style="width: 60px; margin-right: 5px; padding: 5px; border: 1px solid #ccc; border-radius: 5px;" />
                                        <input type="submit" value="В корзину" style="background-color: #4c60d1; color: white; border: none; padding: 6px 15px; border-radius: 20px; cursor: pointer;" />
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                @if (Model.IsAddedSuccess)
                {
                    <p style="margin-top: 15px;"><span class="status-ok">Книга добавлена в корзину!</span> <a asp-page="/Cart">Перейти в корзину</a></p>
                }
            </div>
        </div>

        <!-- РЕЦЕНЗИИ -->
        <div style="text-align: center; margin-top: 40px;">
            <h3 style="border-bottom: 2px solid #4c60d1; display: inline-block; padding-bottom: 5px;">Рецензии читателей @(Model.AverageScore > 0 ? $"({Model.AverageScore:F1} / 5)" : "")</h3>
        </div>

        <div style="max-width: 800px; margin: 0 auto; padding-bottom: 50px;">

            @if (!string.IsNullOrEmpty(Model.ReviewErrorMessage))
            {
                <div style="background-color: #ffe6e6; color: red; padding: 10px; border-radius: 5px; margin-bottom: 15px; font-size: 13px;">
                    <b>Ошибка:</b> @Model.ReviewErrorMessage
                </div>
            }

            @if (Model.ReviewsList == null || !Model.ReviewsList.Any())
            {
                <p style="text-align: center; color: gray; margin-bottom: 30px;"><i>На эту книгу ещё никто не оставил отзывов. Будьте первым!</i></p>
            }
            else
            {
                <div style="display: flex; flex-direction: column; gap: 15px; margin-bottom: 30px;">
                    @foreach (var review in Model.ReviewsList)
                    {
                        <div style="border: 1px solid #e0e0e0; border-radius: 10px; padding: 15px; background-color: #fff; box-shadow: 0 2px 5px rgba(0,0,0,0.02);">
                            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
                                <div>
                                    <b style="color: #4c60d1;">@(review.UserKeyNavigation?.UserLogIn ?? "Покупатель")</b>
                                    <span style="margin-left: 10px; color: #f39c12;">@Html.Raw(new string('★', review.BookScore))@Html.Raw(new string('☆', 5 - review.BookScore))</span>
                                </div>
                                <span style="color: gray; font-size: 12px;">@(review.ReviewDate?.ToString("dd.MM.yyyy") ?? "Дата неизвестна")</span>
                            </div>
                            <p style="margin: 5px 0 0 0; font-size: 14px; line-height: 1.5; white-space: pre-line;">@review.ReviewText</p>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- ФОРМА ДОБАВЛЕНИЯ ОТЗЫВА -->
        @if (User.Identity != null && User.Identity.IsAuthenticated)
        {
            if (Model.UserHasReview)
            {
                <div style="max-width: 800px; margin: 0 auto 30px auto; text-align: center; padding: 15px; background-color: #f5f5f5; border-radius: 10px;">
                    <p style="margin: 0; color: gray;">Вы уже оставили отзыв на эту книгу. Спасибо!</p>
                </div>
            }
            else if (Model.CanLeaveReview)
            {
                <div style="max-width: 800px; margin: 0 auto 30px auto; text-align: center;">
                    <div style="border-top: 2px dashed #b0b288; padding-top: 25px;">
                        <h4 style="margin: 0 0 15px 0; font-size: 16px;">Оставить отзыв о книге:</h4>
                        <form method="post" asp-page-handler="AddReview" asp-route-id="@Model.CurrentBook.BookId">
                            <div style="margin-bottom: 12px;">
                                <label style="font-size: 13px; font-weight: bold; margin-right: 10px;">Ваша оценка:</label>
                                <select asp-for="NewReviewScore" style="padding: 5px; font-family: 'Consolas', monospace; border-radius: 5px; border: 1px solid #b0b288;">
                                    <option value="5">5 ★★★★★</option>
                                    <option value="4">4 ★★★★☆</option>
                                    <option value="3">3 ★★★☆☆</option>
                                    <option value="2">2 ★★☆☆☆</option>
                                    <option value="1">1 ★☆☆☆☆</option>
                                </select>
                            </div>
                            <div style="margin-bottom: 15px;">
                                <textarea asp-for="NewReviewText" rows="4" style="width: 100%; border-radius: 8px; padding: 10px; border: 1px solid #b0b288; font-family: 'Consolas', monospace;" required placeholder="Поделитесь впечатлениями о книге..."></textarea>
                            </div>
                            <div style="text-align: center;">
                                <button type="submit" style="background-color: #4c60d1; color: white; border: none; padding: 8px 25px; border-radius: 20px; cursor: pointer; font-weight: bold;">Опубликовать отзыв</button>
                            </div>
                        </form>
                    </div>
                </div>
            }
            else
            {
                <div style="max-width: 800px; margin: 0 auto 30px auto; text-align: center; padding: 15px; background-color: #f5f5f5; border-radius: 10px;">
                    <p style="margin: 0; color: gray;">Вы можете оставить отзыв только после получения заказа (статус "Выдан клиенту").</p>
                </div>
            }
        }
        else
        {
            <div style="max-width: 800px; margin: 0 auto 30px auto; text-align: center; padding: 15px; background-color: #f5f5f5; border-radius: 10px;">
                <p style="margin: 0; color: gray;"><a asp-page="/Login">Войдите в аккаунт</a>, чтобы оставить отзыв</p>
            </div>
        }
    </div>
}

<script>
    // При изменении типа книги показываем соответствующие предложения
    document.getElementById('selectedBookType')?.addEventListener('change', function() {
        var selectedType = this.value;
        var physicalDiv = document.getElementById('physicalSupplies');
        var electronicDiv = document.getElementById('electronicSupply');

        if (selectedType == '4') {
            if (physicalDiv) physicalDiv.style.display = 'block';
            if (electronicDiv) electronicDiv.style.display = 'none';
        } else {
            if (physicalDiv) physicalDiv.style.display = 'none';
            if (electronicDiv) electronicDiv.style.display = 'block';
        }
    });

    setTimeout(function() {
        var event = new Event('change');
        document.getElementById('selectedBookType')?.dispatchEvent(event);
    }, 100);
</script>