@page
@using web.Models
@model web.Pages.BooksModel
@{
    ViewData["Title"] = "Каталог книг";
}


<!-- СТИЛЬНАЯ СОВРЕМЕННАЯ ФОРМА ФИЛЬТРАЦИИ И ПОИСКА -->
<form method="get" style="margin-bottom: 30px;">
    <div style="display: flex; flex-wrap: wrap; align-items: center; gap: 15px;">

        <!-- Текстовое поле поиска со встроенной лупой -->
        <div style="position: relative; width: 280px;">
            <input type="text"
                   name="SearchString"
                   value="@Model.SearchString"
                   placeholder="Поиск по названию..."
                   style="width: 100%; padding: 8px 35px 8px 12px; font-family: 'Consolas', monospace; font-size: 13px; border: 1px solid #b0b288; border-radius: 20px; box-sizing: border-box; outline: none; background-color: #ffffff;"
                   autocomplete="off" />

            <button type="submit"
                    style="position: absolute; right: 3px; top: 50%; transform: translateY(-50%); background: none; border: none; cursor: pointer; padding: 6px 10px; display: flex; align-items: center; justify-content: center; color: #4c60d1;"
                    title="Найти">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="11" r="8"></circle>
                    <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                </svg>
            </button>
        </div>

        <!-- Выпадающий список авторов -->
        <div style="display: flex; align-items: center; gap: 8px;">
            <select name="SelectedAuthorId" style="padding: 7px 12px; font-family: 'Consolas', monospace; font-size: 13px; border: 1px solid #b0b288; border-radius: 20px; outline: none; background-color: #ffffff; cursor: pointer; width: 200px;">
                <option value="">[Все авторы]</option>
                @if (Model.Authors != null)
                {
                    foreach (var author in Model.Authors)
                    {
                        if (Model.SelectedAuthorId == author.AuthorId)
                        {
                            <option value="@author.AuthorId" selected="selected">@author.AuthorSecondName @author.AuthorFirstName @author.AuthorPatronymic</option>
                        }
                        else
                        {
                            <option value="@author.AuthorId">@author.AuthorSecondName @author.AuthorFirstName @author.AuthorPatronymic</option>
                        }
                    }
                }
            </select>
        </div>

        <!-- Выпадающий список жанров -->
        <div style="display: flex; align-items: center; gap: 8px;">
            <select name="SelectedGenreId" style="padding: 7px 12px; font-family: 'Consolas', monospace; font-size: 13px; border: 1px solid #b0b288; border-radius: 20px; outline: none; background-color: #ffffff; cursor: pointer;">
                <option value="">[Все жанры]</option>
                @if (Model.Genres != null)
                {
                    foreach (var genre in Model.Genres)
                    {
                        if (Model.SelectedGenreId == genre.GenreId)
                        {
                            <option value="@genre.GenreId" selected="selected">@genre.GenreName</option>
                        }
                        else
                        {
                            <option value="@genre.GenreId">@genre.GenreName</option>
                        }
                    }
                }
            </select>
        </div>

        <!-- Выпадающий список типов изданий -->
        <div style="display: flex; align-items: center; gap: 8px;">
            <select name="SelectedTypeId" style="padding: 7px 12px; font-family: 'Consolas', monospace; font-size: 13px; border: 1px solid #b0b288; border-radius: 20px; outline: none; background-color: #ffffff; cursor: pointer;">
                <option value="">[Все типы издания]</option>
                @if (Model.BookTypes != null)
                {
                    foreach (var type in Model.BookTypes)
                    {
                        if (Model.SelectedTypeId == type.BookTypeId)
                        {
                            <option value="@type.BookTypeId" selected="selected">@type.BookTypeName</option>
                        }
                        else
                        {
                            <option value="@type.BookTypeId">@type.BookTypeName</option>
                        }
                    }
                }
            </select>
        </div>

        <div style="display: flex; align-items: center; gap: 8px;">
            <select name="SelectedSupplierId" style="padding: 7px 12px; font-family: 'Consolas', monospace; font-size: 13px; border: 1px solid #b0b288; border-radius: 20px; outline: none; background-color: #ffffff; cursor: pointer;">
                <option value="">[Все издательства]</option>
                @if (Model.Suppliers != null)
                {
                    foreach (var supplier in Model.Suppliers)
                    {
                        if (Model.SelectedSupplierId == supplier.SupplierId)
                        {
                            <option value="@supplier.SupplierId" selected="selected">@supplier.SupplierName</option>
                        }
                        else
                        {
                            <option value="@supplier.SupplierId">@supplier.SupplierName</option>
                        }
                    }
                }
            </select>
        </div>

        <!-- Кнопка применения фильтров - ЧЕРНАЯ С БЕЛЫМ ТЕКСТОМ -->
        <input type="submit" value="Применить" style="padding: 7px 20px; font-family: 'Consolas', monospace; font-size: 13px; background-color: #333333; color: white; border: 1px solid #333333; border-radius: 20px; cursor: pointer; font-weight: bold;" />

        <!-- Кнопка сброса (если фильтры активны) -->
        @if (!string.IsNullOrEmpty(Model.SearchString) || Model.SelectedTypeId.HasValue || Model.SelectedGenreId.HasValue || Model.SelectedSupplierId.HasValue || Model.SelectedAuthorId.HasValue)
        {
            <a href="/Books" style="color: #4c60d1; text-decoration: none; font-size: 13px; font-weight: bold; margin-left: 5px;">[Очистить фильтры]</a>
        }
    </div>
</form>

<!-- Остальной код без изменений -->
@if (Model.Books == null || !Model.Books.Any())
{
    <p style="color: gray; font-weight: bold;">
        По заданным критериям фильтрации ничего не найдено.
        <a href="/Books" style="color: #4c60d1; text-decoration: none;">Сбросить фильтры</a>
    </p>
}
else
{
    <!-- СЕТКА КАРТОЧЕК КНИГ -->
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 30px; margin-bottom: 40px; align-items: flex-start;">

        @foreach (var book in Model.Books)
        {
            <!-- Карточка -->
            <div style="display: flex; flex-direction: column; align-items: center;">

                <!-- Обертка обложки (ссылка) -->
                <a href="/BookDetails?id=@book.BookId" style="width: 100%; text-decoration: none;">
                    <div style="width: 100%; aspect-ratio: 3/4; overflow: hidden; border: 1px solid transparent; background-color: #f9f9f9; border-radius: 8px; display: flex; align-items: center; justify-content: center; margin-bottom: 12px; box-shadow: 0 4px 8px rgba(0,0,0,0.06); transition: box-shadow 0.2s ease;">
                        @if (!string.IsNullOrEmpty(book.ImagePath))
                        {
                            <img src="@book.ImagePath" alt="Обложка" style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.2s ease-in-out;" onmouseover="this.style.transform='scale(1.04)';" onmouseout="this.style.transform='scale(1)';" />
                        }
                        else
                        {
                            <span style="font-size: 12px; color: #7a7c56; font-weight: bold; text-transform: uppercase;">[нет обложки]</span>
                        }
                    </div>
                </a>

                <!-- Название (ссылка) -->
                <a href="/BookDetails?id=@book.BookId" style="text-decoration: none; text-align: center; width: 100%;">
                    <span style="font-size: 13px; font-weight: bold; line-height: 1.3; color: #000000; display: block;" onmouseover="this.style.color='#4c60d1'" onmouseout="this.style.color='#000000'">
                        @book.BookName
                    </span>
                </a>

                <!-- Авторы -->
                <span style="font-size: 11px; color: #555555; font-style: italic; display: block; text-align: center;">
                    @{
                        var authorsForThisBook = Model.BookAuthorsDict.ContainsKey(book.BookId)
                            ? Model.BookAuthorsDict[book.BookId]
                            : new List<Author>();
                    }
                    @if (authorsForThisBook.Any())
                    {
                        <span>
                            @string.Join(", ", authorsForThisBook.Select(a => $"{a.AuthorSecondName} {a.AuthorFirstName[0]}.{(!string.IsNullOrEmpty(a.AuthorPatronymic) ? a.AuthorPatronymic[0] + "." : "")}"))
                        </span>
                    }
                    else
                    {
                        <span style="color:gray;">Автор не указан</span>
                    }
                </span>

                <!-- Жанры -->
                @if (book.BookGenres != null && book.BookGenres.Any())
                {
                    <div style="margin-top: 5px; text-align: center;">
                        @foreach (var bookGenre in book.BookGenres.Take(2))
                        {
                            <span style="font-size: 8px; background-color: #f0f0f0; color: #666; padding: 2px 5px; border-radius: 10px; display: inline-block; margin: 1px;">
                                @bookGenre.GenreKeyNavigation?.GenreName
                            </span>
                        }
                        @if (book.BookGenres.Count() > 2)
                        {
                            <span style="font-size: 8px; color: #999;">+@(book.BookGenres.Count() - 2)</span>
                        }
                    </div>
                }

                <!-- КНОПКА "В КОРЗИНУ" -->
                <div style="margin-top: 10px;">
                    <a href="/BookDetails?id=@book.BookId"
                       style="background-color: #4c60d1; color: white; border: none; padding: 5px 12px; border-radius: 20px; font-size: 11px; cursor: pointer; text-decoration: none; display: inline-block;">
                        В корзину
                    </a>
                </div>

            </div>
        }
    </div>
}