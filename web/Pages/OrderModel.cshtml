@page
@model web.Pages.OrderModel
@{
    ViewData["Title"] = "Оформление заказа";
}

<h2>Ваша корзина</h2>

@if (!Model.CartBooks.Any())
{
    <p>Корзина пуста.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Книга</th>
                <th>Цена</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var book in Model.CartBooks)
            {
                <tr>
                    <td>@book.BookName</td>
                    <td>@book.Price.ToString("C")</td>
                </tr>
            }
        </tbody>
    </table>

    <div class="row">
        <div class="col-md-4">
            <form method="post" asp-page-handler="Checkout">
                <div class="text-danger" asp-validation-summary="All"></div>

                <div class="form-group mb-3">
                    <label class="form-label">Индекс адреса доставки:</label>
                    <input type="text" class="form-control" asp-for="AddressIndex" required maxlength="10" />
                </div>

                <button type="submit" class="btn btn-success">📦 Подтвердить и заказать</button>
            </form>
        </div>
    </div>
}
