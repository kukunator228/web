@page
@model web.Pages.AuthorsModel
@{
    ViewData["Title"] = "Авторы";
}

<!-- Форма поиска (сделали её более аккуратной) -->
<form method="get" style="margin-bottom: 25px;">
    <div style="display: flex; align-items: center; gap: 12px;">
        <!-- Контейнер для поля и иконки -->
        <div style="position: relative; display: inline-block; width: 280px;">
            <!-- Текстовое поле со скруглениями (толщина обводки изменена на 1px) -->
            <input type="text" name="SearchString" value="@Model.SearchString" placeholder="Введите ФИО автора..." style="width: 100%; padding: 7px 35px 7px 12px; font-family: 'Consolas', monospace; font-size: 10px; border: 1px solid #b0b288; border-radius: 20px; box-sizing: border-box; outline: none; background-color: #ffffff;" autocomplete="off" />
            <!-- Кнопка-лупа, прижатая в правый угол внутри поля -->
            <button type="submit" style="position: absolute; right: 3px; top: 50%; transform: translateY(-50%); background: none; border: none; cursor: pointer; padding: 6px 10px; display: flex; align-items: center; justify-content: center; color: #4c60d1;" title="Найти">
                <!-- SVG-иконка лупы (чистый вектор, не нужна картинка в папке) -->
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="11" r="8"></circle>
                    <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                </svg>
            </button>
        </div>
        @if (!string.IsNullOrEmpty(Model.SearchString))
        {
            <a href="/Authors" style="color: #4c60d1; text-decoration: none; font-size: 13px; font-weight: bold;">[Сбросить]</a>
        }
    </div>
</form>

@if (Model.Authors == null || !Model.Authors.Any())
{
    @if (!string.IsNullOrEmpty(Model.SearchString))
    {
        <p style="color: grey ;">В нашем каталоге нет "<b>@Model.SearchString</b>". Но вы можете заполнить заявку и мы постараемся найти желаемую книгу! <a href="/Authors">Показать всех</a></p>
    }
}
else
{
    <!-- СЕТКА КАРТОЧЕК АВТОРОВ -->
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 25px; margin-bottom: 30px;">
        @foreach (var item in Model.Authors)
        {
            <!-- Ссылка-контейнер: делает всю карточку кликабельной -->
            <a asp-page="/AuthorBooks" asp-route-AuthorId="@item.AuthorId" style="text-decoration: none; color: inherit; display: flex; flex-direction: column; align-items: center;">
                <!-- Обертка для портрета (обводка сделана прозрачной) -->
                <div style="width: 100%; aspect-ratio: 3/4; overflow: hidden; border: 2px solid transparent; background-color: #f9f9f9; display: flex; align-items: center; justify-content: center; margin-bottom: 10px; border-radius: 10px; box-shadow: 0 2px 5px rgba(0,0,0,0.05);">
                    @if (!string.IsNullOrEmpty(item.ImagePath))
                    {
                        <img src="@item.ImagePath" alt="Фото" style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.2s ease-in-out;" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'" />
                    }
                    else
                    {
                        <!-- Заглушка, если фото нет -->
                        <span style="font-size: 12px; color: #7a7c56; font-weight: bold; text-transform: uppercase;">[нет фото]</span>
                    }
                </div>
                <!-- Интерактивная подпись внизу карточки -->
                <div style="text-align: center; width: 100%; padding: 0 5px;">
                    <!-- ФИО автора мелким шрифтом -->
                    <span style="font-size: 13px; font-weight: bold; line-height: 1.2; display: block; color: #000000;" onmouseover="this.style.color='#4c60d1'" onmouseout="this.style.color='#000000'">
                        @item.AuthorSecondName<br />
                        @item.AuthorFirstName @item.AuthorPatronymic
                    </span>
                </div>
            </a>
        }
    </div>
}
